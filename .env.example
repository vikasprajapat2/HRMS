# Flask Configuration
SECRET_KEY=your-super-secret-key-change-in-production

# ==========================================
# Database Configuration - Choose ONE option
# ==========================================

# OPTION 1: Supabase / PostgreSQL (Recommended for production)
# Make sure to use the IPv4 Connection Pooler URL from your Supabase Dashboard
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# OPTION 2: MySQL Integration
# Uncomment these if you want to connect to a MySQL instance instead
# MYSQL_USER=root
# MYSQL_PASSWORD=your_mysql_password
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_DATABASE=hrms_db

# OPTION 3: SQLite (Default Local Testing)
# If neither DATABASE_URL nor MySQL variables are provided, 
# the application will default to automatically creating a local SQLite file (employee_management.db)

# ==========================================
# Additional APIs
# ==========================================

# Optional: Supabase REST API credentials (if using supabase python client)
# SUPABASE_URL=https://[your-project-ref].supabase.co
# SUPABASE_KEY=your-supabase-anon-public-key
